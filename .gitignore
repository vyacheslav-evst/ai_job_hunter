# Секреты и чувствительные данные — никогда не коммитить
.env

# Личное резюме с реальными данными — хранится только локально
# Используй memory/base_resume.example.json как шаблон
memory/base_resume.json

# Виртуальное окружение Python
.venv/
venv/
env/

