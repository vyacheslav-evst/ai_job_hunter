# Скопируй этот файл в .env и заполни своими ключами
# Windows: copy .env.example .env
# Linux/macOS: cp .env.example .env

# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenAI ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Модель (рекомендуется gpt-4o-mini — дёшево и быстро)
LLM_MODEL=gpt-4o-mini

# ── Настройки поиска ──────────────────────────────────────────────────────────
# Активный пресет профессии (см. config.py — PROFESSION_PRESETS)
# Варианты: "AI/ML + Python Junior", "AI/ML Engineer", "Python Developer",
#           "Data Analyst", "Frontend Developer"
PROFESSION_PRESET=AI/ML + Python Junior

# 113 = вся Россия, 1 = Москва, 2 = Санкт-Петербург
SEARCH_AREA=113

# Минимальный score для включения вакансии в отчёт (0-100)
RELEVANCE_THRESHOLD=45

# ── Прокси (если OpenAI API недоступен напрямую из твоей страны) ──────────────
# Формат: http://host:port  или  http://user:pass@host:port
# Оставь пустым если VPN работает на уровне системы
HTTPS_PROXY=
HTTP_PROXY=
