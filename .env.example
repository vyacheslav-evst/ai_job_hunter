# Скопируй этот файл в .env и заполни своими ключами
# cp .env.example .env  (Linux/macOS)
# copy .env.example .env  (Windows)

# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenAI ключ: https://platform.openai.com/api-keys
# Или OpenRouter ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Модель (рекомендуется gpt-4o-mini — дёшево и быстро)
LLM_MODEL=gpt-4o-mini

# ── Настройки поиска ──────────────────────────────────────────────────────────
# 113 = вся Россия, 1 = Москва, 2 = Санкт-Петербург
SEARCH_AREA=113

# Минимальный score для отображения вакансии (0-100)
RELEVANCE_THRESHOLD=45

# ── Прокси (если LLM API недоступен напрямую из твоей страны) ─────────────────
# Формат: http://host:port  или  http://user:pass@host:port
# Оставь пустым если VPN работает на уровне системы
HTTPS_PROXY=
HTTP_PROXY=
